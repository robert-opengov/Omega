# ============================================================================
# GAB Verticals Boilerplate — Environment Variables
# Copy to .env.local and fill in real values. Never commit .env.local.
# ============================================================================

# --- GAB API ---
# Base URL for all API calls (/token, /api/*)
NEXT_PUBLIC_API_URL=https://devapi.ignatius.io

# OAuth client_id sent with every /token request
GAB_CLIENT_ID=IAFConsulting

# Service account for server-to-server operations (optional, for M2M flows)
# GAB_SERVICE_USERNAME=
# GAB_SERVICE_PASSWORD=

# --- App-specific keys (AI/dev fills these per vertical) ---
# GAB_APP_KEY=
# GAB_TABLE_SERVICE_REQUESTS=
# GAB_TABLE_ACTIVITIES=

# ============================================================================
# App Customization (optional — override defaults in config/app.config.ts)
# ============================================================================
NEXT_PUBLIC_APP_NAME=My GAB Application
NEXT_PUBLIC_APP_DESCRIPTION=Built with the GAB Verticals Boilerplate

# Theme colors (hex) — change any of these to rebrand the entire UI
# Defaults are aligned with OpenGov CDS-37 design system
# IMPORTANT: hex values must be quoted because # starts a comment in .env files
NEXT_PUBLIC_THEME_PRIMARY="#4B3FFF"
# NEXT_PUBLIC_THEME_SECONDARY="#757575"
# NEXT_PUBLIC_THEME_SUCCESS="#2E7D32"
# NEXT_PUBLIC_THEME_WARNING="#ED6C02"
# NEXT_PUBLIC_THEME_DANGER="#D32F2F"
# NEXT_PUBLIC_THEME_INFO="#0288D1"
# NEXT_PUBLIC_THEME_IN_PROGRESS="#7B1FA2"

# Custom logo URL for whitelabel deployments (shows in navbar and sidebar)
# NEXT_PUBLIC_LOGO_URL=https://example.com/logo.svg

# Login page hero image (left panel of the split layout)
# Defaults to /brand/login.png. Override with any URL or path to a local asset.
# NEXT_PUBLIC_LOGIN_HERO_IMAGE=/brand/login.svg

# Layout — controls which chrome (navbar, sidebar, or both) is rendered.
# Simple boolean flags (preferred):
# NEXT_PUBLIC_SHOW_NAVBAR=true
# NEXT_PUBLIC_SHOW_SIDEBAR=true
#
# Legacy shorthand (overrides the booleans above if set):
# Options: navbar-sidebar (default), navbar-only, sidebar-only
# NEXT_PUBLIC_LAYOUT_MODE=navbar-sidebar

# ============================================================================
# AI (used by the AI Builder chat — optional)
# ============================================================================
# OPENAI_API_KEY=

# ============================================================================
# Runtime
# ============================================================================
NODE_ENV=development
