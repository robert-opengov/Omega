# ===================================================
# GAB Verticals Boilerplate — Environment Variables
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# Required variables are uncommented. Optional ones are
# commented out with their defaults shown.
# ===================================================

# --- GAB API (required) ----------------------------------------
NEXT_PUBLIC_API_URL=https://devapi.ignatius.io
GAB_CLIENT_ID=IAFConsulting
# GAB_API_VERSION=v1                      # v1 or v2 (default: v1)

# --- App Identity ----------------------------------------------
# NEXT_PUBLIC_APP_NAME=GAB Application
# NEXT_PUBLIC_APP_DESCRIPTION=Powered by GAB
# NEXT_PUBLIC_LOGO_URL=
# NEXT_PUBLIC_LOGIN_HERO_IMAGE=/brand/login.png

# --- Theme Colors (hex) ----------------------------------------
# NEXT_PUBLIC_THEME_PRIMARY=#4B3FFF
# NEXT_PUBLIC_THEME_SECONDARY=#757575
# NEXT_PUBLIC_THEME_SUCCESS=#2E7D32
# NEXT_PUBLIC_THEME_WARNING=#ED6C02
# NEXT_PUBLIC_THEME_DANGER=#D32F2F
# NEXT_PUBLIC_THEME_INFO=#0288D1
# NEXT_PUBLIC_THEME_IN_PROGRESS=#7B1FA2

# --- Layout ----------------------------------------------------
# NEXT_PUBLIC_LAYOUT_MODE=navbar-sidebar   # navbar-sidebar | navbar-only | sidebar-only | none
# NEXT_PUBLIC_SHOW_NAVBAR=true
# NEXT_PUBLIC_SHOW_SIDEBAR=true

# --- Auth Strategy (server-only) -------------------------------
# AUTH_ENABLED=true                        # false to disable all auth
# AUTH_LOGIN_MODE=both                     # password | sso | both
# AUTH_ENABLE_SILENT_LOGIN=                # true/false (default depends on login mode)

# --- Auth0 SSO -------------------------------------------------
# NEXT_PUBLIC_AUTH0_DOMAIN=
# NEXT_PUBLIC_AUTH0_CLIENT_ID=
# NEXT_PUBLIC_AUTH0_AUDIENCE=

# --- Feature Flags ---------------------------------------------
# On by default (set =false to disable):
# NEXT_PUBLIC_ENABLE_DARK_MODE=true
# NEXT_PUBLIC_ENABLE_SIGNUP=true
#
# Off by default (set =true to enable):
# NEXT_PUBLIC_ENABLE_I18N=false
# NEXT_PUBLIC_ENABLE_NOTIFICATIONS=false
# NEXT_PUBLIC_ENABLE_GRANTS=false
# NEXT_PUBLIC_ENABLE_311=false

# --- Service Account (server-only, optional) -------------------
# GAB_SERVICE_USERNAME=
# GAB_SERVICE_PASSWORD=
# GAB_APP_KEY=
# GAB_TABLE_SERVICE_REQUESTS=
# GAB_TABLE_ACTIVITIES=

# --- AI (optional) ---------------------------------------------
# OPENAI_API_KEY=
