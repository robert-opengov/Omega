# ============================================================================
# GAB Verticals Boilerplate — Environment Variables
# Copy to .env.local and fill in real values. Never commit .env.local.
# ============================================================================

# --- GAB API ---
# API version: 'v1' (legacy) or 'v2' (default).
# The correct API URL is resolved automatically per version:
#   v1 → https://devapi.ignatius.io
#   v2 → https://gab-core-api.gab.ogintegration.us
# Override with GAB_API_URL only for custom deployments.
GAB_API_VERSION=v2

# --- V1-only (uncomment when GAB_API_VERSION=v1) ---
# GAB_CLIENT_ID=IAFConsulting

# Service account for server-to-server operations (optional, for M2M flows)
# GAB_SERVICE_USERNAME=
# GAB_SERVICE_PASSWORD=

# --- App-specific keys (AI/dev fills these per vertical) ---
# GAB_APP_KEY=
# GAB_TABLE_SERVICE_REQUESTS=
# GAB_TABLE_ACTIVITIES=

# ============================================================================
# App Customization (optional — override defaults in config/app.config.ts)
# ============================================================================
NEXT_PUBLIC_APP_NAME=My GAB Application
NEXT_PUBLIC_APP_DESCRIPTION=Built with the GAB Verticals Boilerplate
# Base URL for Open Graph / social link unfurls (absolute URL required for og:image)
# NEXT_PUBLIC_SITE_URL=https://your-app.example.gov

# Theme colors (hex) — change any of these to rebrand the entire UI
# Defaults are aligned with OpenGov CDS-37 design system
# IMPORTANT: hex values must be quoted because # starts a comment in .env files
NEXT_PUBLIC_THEME_PRIMARY="#4B3FFF"
# NEXT_PUBLIC_THEME_SECONDARY="#757575"
# NEXT_PUBLIC_THEME_SUCCESS="#2E7D32"
# NEXT_PUBLIC_THEME_WARNING="#ED6C02"
# NEXT_PUBLIC_THEME_DANGER="#D32F2F"
# NEXT_PUBLIC_THEME_INFO="#0288D1"
# NEXT_PUBLIC_THEME_IN_PROGRESS="#7B1FA2"

# Custom logo URL for whitelabel deployments (shows in navbar and sidebar)
# NEXT_PUBLIC_LOGO_URL=https://example.com/logo.svg

# Login page hero image (left panel of the split layout)
# Defaults to /brand/login.webp. Override with any URL or path to a local asset.
# NEXT_PUBLIC_LOGIN_HERO_IMAGE=/brand/demo-login-boston.webp

# Layout — controls which chrome (navbar, sidebar, or both) is rendered.
# Simple boolean flags (preferred):
# NEXT_PUBLIC_SHOW_NAVBAR=true
# NEXT_PUBLIC_SHOW_SIDEBAR=true
#
# Legacy shorthand (overrides the booleans above if set):
# Options: navbar-sidebar (default), navbar-only, sidebar-only, none
# NEXT_PUBLIC_LAYOUT_MODE=navbar-sidebar

# ============================================================================
# Auth Strategy (server-only, secure — no NEXT_PUBLIC_ prefix)
# ============================================================================

# Master auth switch. Set to 'false' for public landing pages or kiosk apps.
# When disabled, middleware skips all redirects and root / always goes to /home.
# AUTH_ENABLED=true

# Login mode: 'password' | 'sso' | 'both' (default: both)
# - password: only username/password form
# - sso: only SSO button (OpenGov Auth0)
# - both: password form + SSO button (matches gab-frontend default)
# AUTH_LOGIN_MODE=both

# Silent SSO login: auto-login if user has an active Auth0 session.
# Defaults to true for sso mode, false for both mode.
# AUTH_ENABLE_SILENT_LOGIN=false

# --- Auth0 SSO (required when AUTH_LOGIN_MODE is 'sso' or 'both') ---
# Domain for the Auth0 tenant (without https://)
# NEXT_PUBLIC_AUTH0_DOMAIN=login.ogintegration.us
# Auth0 application client ID
# NEXT_PUBLIC_AUTH0_CLIENT_ID=
# Auth0 API audience identifier
# NEXT_PUBLIC_AUTH0_AUDIENCE=opengov

# ============================================================================
# Feature Flags
# "On by default" flags use !== 'false' (opt-out).
# "Off by default" flags use === 'true' (opt-in).
# ============================================================================

# Dark mode toggle in navbar (on by default)
# NEXT_PUBLIC_ENABLE_DARK_MODE=true

# Self-registration / signup page (on by default)
# NEXT_PUBLIC_ENABLE_SIGNUP=true

# i18n / multi-language support (off by default)
# NEXT_PUBLIC_ENABLE_I18N=false

# Notification badge in navbar (off by default)
# NEXT_PUBLIC_ENABLE_NOTIFICATIONS=false

# Site identifier banner above the navbar (off by default)
# When enabled, set NEXT_PUBLIC_SITE_BANNER_ORG at minimum.
# NEXT_PUBLIC_ENABLE_SITE_BANNER=false
# NEXT_PUBLIC_SITE_BANNER_ORG="CITY of BOSTON"
# NEXT_PUBLIC_SITE_BANNER_LOGO_URL=https://example.com/city-seal.svg
# NEXT_PUBLIC_SITE_BANNER_STATEMENT="An official website of the City of Boston."
# NEXT_PUBLIC_SITE_BANNER_VARIANT=dark

# ============================================================================
# Module Flags (vertical kill switches — see config/modules.config.ts)
# Set any to 'false' to hide the navigation entry AND 404 the route.
# Defaults: every module ships ON.
#
# Precedence (highest wins):
#   1. Cookie override written by the in-app /settings/modules UI
#      (admin/superadmin only, per-browser, persists 1 year).
#   2. NEXT_PUBLIC_MODULE_* env var below (baseline at build time).
#   3. The hard-coded default in config/modules.config.ts.
#
# Use env vars for environment-wide kill switches and the UI for
# experimentation / staging tweaks.
# ============================================================================

# Platform shells
# NEXT_PUBLIC_MODULE_PLATFORM_TENANTS=true     # /companies
# NEXT_PUBLIC_MODULE_PLATFORM_USERS=true       # /users
# NEXT_PUBLIC_MODULE_PLATFORM_TEMPLATES=true   # /templates
# NEXT_PUBLIC_MODULE_PLATFORM_AI_BUILDER=true  # /ai-builder
# NEXT_PUBLIC_MODULE_PLATFORM_UI_SHOWCASE=true # /ui

# Per-app verticals (each tab inside /apps/[appId]/...)
# NEXT_PUBLIC_MODULE_APP_OVERVIEW=true
# NEXT_PUBLIC_MODULE_APP_TABLES=true
# NEXT_PUBLIC_MODULE_APP_RELATIONSHIPS=true
# NEXT_PUBLIC_MODULE_APP_ROLES=true
# NEXT_PUBLIC_MODULE_APP_NOTIFICATIONS=true
# NEXT_PUBLIC_MODULE_APP_JOBS=true
# NEXT_PUBLIC_MODULE_APP_AUDIT=true
# NEXT_PUBLIC_MODULE_APP_FORMS=true
# NEXT_PUBLIC_MODULE_APP_REPORTS=true
# NEXT_PUBLIC_MODULE_APP_PAGES=true
# NEXT_PUBLIC_MODULE_APP_CUSTOM_COMPONENTS=true
# NEXT_PUBLIC_MODULE_APP_WORKFLOWS=true
# NEXT_PUBLIC_MODULE_APP_SANDBOX=true
# NEXT_PUBLIC_MODULE_APP_SETTINGS=true

# Backend services
# NEXT_PUBLIC_MODULE_SERVICES_OCR=true
# NEXT_PUBLIC_MODULE_SERVICES_AI=true

# Page-builder palette gates
# NEXT_PUBLIC_MODULE_PAGE_BUILDER_BUILTINS=true          # all built-in widgets
# NEXT_PUBLIC_MODULE_PAGE_BUILDER_CUSTOM_COMPONENTS=true # app-scoped custom widgets

# ============================================================================
# GAB Bedrock AI Gateway (server-only — no NEXT_PUBLIC_ prefix)
# Token is stored in SSM Parameter Store for production.
# ============================================================================
# AI_GATEWAY_BASE_URL=https://gab-bedrock-ai-gateway.gab-test.com
# AI_GATEWAY_TOKEN=
# AI_GATEWAY_DEFAULT_MODEL=global.anthropic.claude-sonnet-4-5-20250929-v1:0

# ============================================================================
# OCR Service (server-only)
# ============================================================================
# OCR_SERVICE_URL=
# Set USE_MOCK_OCR=true to bypass the real OCR microservice and use an
# in-memory mock that simulates the startJob → poll → getResult lifecycle.
USE_MOCK_OCR=true

# ============================================================================
# Runtime
# ============================================================================
NODE_ENV=development
